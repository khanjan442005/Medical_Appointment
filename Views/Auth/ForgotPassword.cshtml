@model ForgotPasswordInputModel
@{
    ViewData["Title"] = "Forgot Password";
    ViewData["AuthTag"] = "Recovery";
    ViewData["AuthTitle"] = "Recover access to your account.";
    ViewData["AuthSubtitle"] = "Use your email address to continue to the password reset step.";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<section class="auth-form-card glass-surface tilt-card" data-tilt>
    <span class="eyebrow">Recovery</span>
    <h2>Forgot password</h2>
    <p>Enter your email address to continue.</p>

    @if (ViewData.ModelState[string.Empty]?.Errors.Count > 0)
    {
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mt-3"></div>
    }

    <form asp-action="ForgotPassword" method="post" class="auth-form-stack">
        <div>
            <label class="auth-label">Email</label>
            <input asp-for="Email" type="email" class="form-control" placeholder="name@medicore.com" data-strict-email="true" />
            <span asp-validation-for="Email" class="text-danger small d-block mt-2"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Send reset link</button>
    </form>

    <div class="auth-switch">
        Remembered it?
        <a asp-action="Login">Back to login</a>
    </div>
</section>
