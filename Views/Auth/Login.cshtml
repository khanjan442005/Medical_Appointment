@model LoginInputModel
@{
    ViewData["Title"] = "Login";
    ViewData["AuthTag"] = "Portal access";
    ViewData["AuthTitle"] = "Sign in to the MediCore platform.";
    ViewData["AuthSubtitle"] = "Access patient, doctor, or admin workflows through one clear login experience.";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<section class="auth-form-card glass-surface tilt-card" data-tilt>
    <span class="eyebrow">Sign in</span>
    <h2>Enter MediCore</h2>
    <p>Select your role and continue to the relevant dashboard.</p>

    @if (ViewData.ModelState[string.Empty]?.Errors.Count > 0)
    {
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mt-3"></div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mt-3">@TempData["Success"]</div>
    }

    <form method="post" class="auth-form-stack">
        <div>
            <label class="auth-label">Role</label>
            <div class="role-pills">
                @foreach (var role in LoginInputModel.SupportedRoles)
                {
                    <label class="role-pill">
                        <input asp-for="Role" type="radio" value="@role" />
                        <span>@role</span>
                    </label>
                }
            </div>
            <span asp-validation-for="Role" class="text-danger small d-block mt-2"></span>
        </div>

        <div>
            <label class="auth-label">Email</label>
            <input asp-for="Email" type="email" class="form-control" placeholder="name@medicore.com" data-strict-email="true" />
            <span asp-validation-for="Email" class="text-danger small d-block mt-2"></span>
        </div>

        <div>
            <label class="auth-label">Password</label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
            <span asp-validation-for="Password" class="text-danger small d-block mt-2"></span>
        </div>

        <div class="auth-links">
            <a asp-controller="Auth" asp-action="ForgotPassword">Forgot password?</a>
            <span class="soft-text">Secure access</span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Login</button>
    </form>

    <div class="auth-switch">
        New to MediCore?
        <a asp-controller="Auth" asp-action="Register">Choose registration type</a>
    </div>
</section>
