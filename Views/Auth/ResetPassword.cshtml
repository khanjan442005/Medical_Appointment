@model ResetPasswordInputModel
@{
    ViewData["Title"] = "Reset Password";
    ViewData["AuthTag"] = "Password reset";
    ViewData["AuthTitle"] = "Set a new password.";
    ViewData["AuthSubtitle"] = "Update your password and return to the login page.";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<section class="auth-form-card glass-surface tilt-card" data-tilt>
    <span class="eyebrow">Reset</span>
    <h2>Set a new password</h2>
    <p>Create a new password for your account.</p>

    @if (ViewData.ModelState[string.Empty]?.Errors.Count > 0)
    {
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mt-3"></div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mt-3">@TempData["Success"]</div>
    }

    <form asp-action="ResetPassword" method="post" class="auth-form-stack">
        <input asp-for="Email" type="hidden" />

        <div>
            <label class="auth-label">Email</label>
            <input type="email" class="form-control" value="@Model.Email" readonly />
        </div>

        <div>
            <label class="auth-label">New password</label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Enter new password" data-password-policy="strong" data-required-message="New password is required." />
            <span asp-validation-for="Password" class="text-danger small d-block mt-2"></span>
        </div>

        <div>
            <label class="auth-label">Confirm password</label>
            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm new password" data-confirm-password="true" data-required-message="Confirm password is required." />
            <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mt-2"></span>
        </div>

        <button type="submit" class="btn btn-success w-100">Reset password</button>
    </form>

    <div class="auth-switch">
        Want to sign in directly?
        <a asp-action="Login">Back to login</a>
    </div>
</section>
