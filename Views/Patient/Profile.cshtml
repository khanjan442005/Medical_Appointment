@model PatientProfileViewModel
@{
    ViewData["Title"] = "Profile";
    ViewData["PageTitle"] = "Profile";
    ViewData["PageSubtitle"] = "Review patient profile details and live account activity from one organized page.";
    Layout = "~/Views/Patient/_PatientLayout.cshtml";
}

<section class="profile-shell glass-surface tilt-card" data-tilt>
    <img src="@Model.Patient.AvatarPath" alt="@Model.Patient.FullName" class="avatar-xl" />
    <div>
        <span class="eyebrow">Patient account</span>
        <h2 class="mt-3 mb-1">@Model.Patient.FullName</h2>
        <p class="mb-2">@Model.Patient.StatusLabel</p>
        <span class="status-tag">Profile active</span>
    </div>
</section>

<section class="detail-grid">
    <article class="detail-card">
        <strong>Email</strong>
        <span class="soft-text">@Model.Patient.Email</span>
    </article>
    <article class="detail-card">
        <strong>Phone</strong>
        <span class="soft-text">@Model.Patient.Phone</span>
    </article>
    <article class="detail-card">
        <strong>Address</strong>
        <span class="soft-text">@Model.Patient.Address</span>
    </article>
    <article class="detail-card">
        <strong>Date of birth</strong>
        <span class="soft-text">@Model.Patient.DateOfBirthLabel</span>
    </article>
    <article class="detail-card">
        <strong>Active appointments</strong>
        <span class="soft-text">@Model.ActiveAppointmentsCount.ToString("D2") current appointment(s)</span>
    </article>
    <article class="detail-card">
        <strong>Notifications</strong>
        <span class="soft-text">@Model.NotificationCount.ToString("D2") recent alert(s)</span>
    </article>
</section>

<section class="section-card glass-surface">
    <div class="section-head">
        <div>
            <span class="eyebrow">Actions</span>
            <h3>Profile management</h3>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-3">
        <a class="btn btn-primary" asp-action="AppointmentHistory">View history</a>
        <a class="btn-brand-outline" asp-action="Notifications">View notifications</a>
    </div>
</section>
