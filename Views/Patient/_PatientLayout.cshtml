@inject IDemoPortalService PortalService
@{
    var patient = PortalService.GetCurrentPatient();
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    var pageTitle = ViewData["PageTitle"] as string ?? action;
    var pageSubtitle = ViewData["PageSubtitle"] as string ?? "Manage bookings, doctors, payments, and medical history from one patient dashboard.";
    var navItems = new[]
    {
        new { Action = "Dashboard", Label = "Overview", Hint = "Daily care snapshot", Index = "01" },
        new { Action = "FindDoctor", Label = "Find Doctors", Hint = "Search specialists", Index = "02" },
        new { Action = "BookAppointment", Label = "Book Visit", Hint = "Schedule new care", Index = "03" },
        new { Action = "AppointmentHistory", Label = "History", Hint = "Review previous visits", Index = "04" },
        new { Action = "Notifications", Label = "Notifications", Hint = "Track alerts and updates", Index = "05" },
        new { Action = "Profile", Label = "Profile", Hint = "Manage personal details", Index = "06" }
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - MediCore</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="panel-shell panel-patient">
    <div class="ambient-layer">
        <span class="ambient-orb orb-a" data-orbit></span>
        <span class="ambient-orb orb-b" data-orbit></span>
        <span class="ambient-orb orb-c" data-orbit></span>
    </div>

    <div class="panel-layout">
        <aside class="panel-sidebar glass-surface">
            <div class="panel-sidebar-top">
                <a class="brand-lockup" asp-controller="Patient" asp-action="Dashboard">
                    <span class="brand-mark">MC</span>
                    <span class="brand-copy">
                        <strong>Patient Panel</strong>
                        <span>Care dashboard</span>
                    </span>
                </a>

                <button class="nav-toggle panel-nav-toggle" type="button" data-nav-toggle data-nav-target="patient-nav-panel" aria-expanded="false" aria-controls="patient-nav-panel">
                    <span class="nav-toggle-box" aria-hidden="true">
                        <span></span>
                        <span></span>
                        <span></span>
                    </span>
                    Menu
                </button>
            </div>

            <div class="panel-sidebar-body" id="patient-nav-panel" data-nav-panel>
                <section class="panel-role-card">
                    <div class="panel-role-copy">
                        <span class="panel-role-badge">Patient workspace</span>
                        <strong>@patient.FullName</strong>
                        <p class="soft-text mb-0">Doctors, bookings, and updates now stay inside one cleaner navigation flow.</p>
                    </div>
                    <span class="avatar-pill avatar-pill-lg">@patient.Initials</span>
                </section>

                <div class="panel-nav-head">
                    <span class="soft-text">Navigation grid</span>
                    <strong>Care actions</strong>
                </div>

                <nav class="panel-nav" aria-label="Patient navigation">
                    @foreach (var item in navItems)
                    {
                        <a class="panel-link @(action == item.Action ? "active" : "")" asp-controller="Patient" asp-action="@item.Action">
                            <span class="panel-link-copy">
                                <strong>@item.Label</strong>
                                <small>@item.Hint</small>
                            </span>
                            <span class="panel-link-index">@item.Index</span>
                        </a>
                    }
                </nav>

                <section class="panel-status glass-surface tilt-card" data-tilt>
                    <span class="soft-text">Health sync</span>
                    <strong>Care activity ready</strong>
                    <p class="soft-text mb-0">Appointments, payments, and notifications stay grouped in one clear view.</p>
                </section>
            </div>
        </aside>

        <div class="panel-main">
            <header class="panel-topbar glass-surface">
                <div class="panel-heading">
                    <span class="eyebrow">Patient Panel</span>
                    <h1>@pageTitle</h1>
                    <p class="soft-text mb-0">@pageSubtitle</p>
                </div>

                <div class="panel-topbar-actions">
                    <div class="panel-context-line">
                        <span class="panel-context-pill">New navigation system</span>
                        <span class="panel-context-pill subtle">Patient dashboard</span>
                    </div>

                    <div class="panel-action-row">
                        <a class="btn-surface" asp-controller="Patient" asp-action="Notifications">Alerts</a>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn-brand-outline">Log Out</button>
                        </form>
                        <div class="panel-user-chip">
                            <span class="avatar-pill">@patient.Initials</span>
                            <div class="panel-user-meta">
                                <strong>@patient.FullName</strong>
                                <span class="panel-user-role">Patient account</span>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <main class="panel-page">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("PageScripts", required: false)
</body>
</html>
