@model PaymentViewModel
@{
    ViewData["Title"] = "Payment";
    ViewData["PageTitle"] = "Payment";
    ViewData["PageSubtitle"] = "Confirm payment and move appointment into doctor schedule and admin reports instantly.";
    Layout = "~/Views/Patient/_PatientLayout.cshtml";
}

<section class="dual-grid">
    <article class="section-card glass-surface">
        <div class="section-head">
            <div>
                <span class="eyebrow">Payment method</span>
                <h3>Choose how you want to pay</h3>
            </div>
        </div>

        @if (ViewData.ModelState[string.Empty]?.Errors.Count > 0)
        {
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
        }

        <form method="post" class="auth-form-stack" data-payment-form>
            <input asp-for="Input.AppointmentId" type="hidden" />

            <div class="payment-options">
                @foreach (var method in PaymentInputModel.SupportedMethods)
                {
                    var methodId = $"payment-method-{method.Replace(" ", string.Empty).ToLowerInvariant()}";
                    <label class="payment-option">
                        <input asp-for="Input.PaymentMethod" id="@methodId" type="radio" value="@method" data-payment-method />
                        <span>
                            @method
                            <small>
                                @(method switch
                                {
                                    "Card" => "Visa, Mastercard, RuPay",
                                    "UPI" => "Google Pay, PhonePe, Paytm",
                                    "Net Banking" => "Direct bank payment",
                                    _ => "Pay during your visit"
                                })
                            </small>
                        </span>
                    </label>
                }
            </div>
            <span asp-validation-for="Input.PaymentMethod" class="text-danger small d-block mt-2"></span>

            <div class="detail-card mt-4">
                <strong>Payment note</strong>
                <span class="soft-text" data-payment-note>
                    UPI and bank payments confirm instantly. Card details are only needed when you choose card payment.
                </span>
            </div>

            <div class="detail-grid mt-4" data-card-fields>
                <div class="detail-card">
                    <strong>Card number</strong>
                    <input asp-for="Input.CardNumber" class="form-control mt-3" placeholder="1234 5678 9012 3456" />
                    <span asp-validation-for="Input.CardNumber" class="text-danger small d-block mt-2"></span>
                </div>
                <div class="detail-card">
                    <strong>Expiry and CVC</strong>
                    <div class="row g-3 mt-1">
                        <div class="col-6">
                            <input asp-for="Input.Expiry" class="form-control" placeholder="MM/YY" />
                            <span asp-validation-for="Input.Expiry" class="text-danger small d-block mt-2"></span>
                        </div>
                        <div class="col-6">
                            <input asp-for="Input.Cvc" class="form-control" placeholder="CVC" />
                            <span asp-validation-for="Input.Cvc" class="text-danger small d-block mt-2"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-grid gap-3">
                <button type="submit" class="btn-brand">Pay @PortalFormatting.FormatCurrency(Model.Appointment.TotalAmount)</button>
                <a class="btn-brand-outline" asp-action="BookAppointment" asp-route-doctorId="@Model.Doctor.Id">Back to booking</a>
            </div>
        </form>
    </article>

    <article class="section-card glass-surface">
        <div class="section-head">
            <div>
                <span class="eyebrow">Summary</span>
                <h3>Booking charges</h3>
            </div>
        </div>

        <div class="summary-list">
            <div class="summary-row">
                <span>Patient</span>
                <strong>@Model.Patient.FullName</strong>
            </div>
            <div class="summary-row">
                <span>Doctor</span>
                <strong>@Model.Doctor.FullName</strong>
            </div>
            <div class="summary-row">
                <span>Appointment</span>
                <strong>@PortalFormatting.FormatDate(Model.Appointment.AppointmentDate), @Model.Appointment.TimeSlot</strong>
            </div>
            <div class="summary-row">
                <span>Consultation fee</span>
                <strong>@PortalFormatting.FormatCurrency(Model.Appointment.ConsultationFee)</strong>
            </div>
            <div class="summary-row">
                <span>Platform fee</span>
                <strong>@PortalFormatting.FormatCurrency(Model.Appointment.PlatformFee)</strong>
            </div>
            <div class="summary-row">
                <span>Total amount</span>
                <strong>@PortalFormatting.FormatCurrency(Model.Appointment.TotalAmount)</strong>
            </div>
        </div>

        <div class="detail-card mt-4">
            <strong>Live sync</strong>
            <span class="soft-text">Once payment is confirmed, this booking is marked as confirmed in the doctor panel and the admin revenue and report counts are updated automatically.</span>
        </div>
    </article>
</section>
