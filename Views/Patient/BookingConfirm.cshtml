@model BookingConfirmationViewModel
@{
    ViewData["Title"] = "Booking Confirmed";
    ViewData["PageTitle"] = "Booking Confirmed";
    ViewData["PageSubtitle"] = "Your appointment has been saved successfully and synced across the platform.";
    Layout = "~/Views/Patient/_PatientLayout.cshtml";
}

<section class="confirmation-shell glass-surface tilt-card" data-tilt>
    <div class="confirmation-mark">OK</div>
    <span class="eyebrow">Confirmation</span>
    <h2 class="mt-3">Your appointment has been confirmed.</h2>
    <p class="soft-text mb-4">
        @Model.Doctor.FullName has been booked for @PortalFormatting.FormatDate(Model.Appointment.AppointmentDate) at @Model.Appointment.TimeSlot.
        The doctor schedule, patient notifications, and admin revenue metrics have all been updated.
    </p>

    <div class="detail-grid text-start">
        <div class="detail-card">
            <strong>Doctor</strong>
            <span class="soft-text">@Model.Doctor.FullName, @Model.Doctor.Specialization</span>
        </div>
        <div class="detail-card">
            <strong>Time</strong>
            <span class="soft-text">@PortalFormatting.FormatDate(Model.Appointment.AppointmentDate), @Model.Appointment.TimeSlot</span>
        </div>
        <div class="detail-card">
            <strong>Payment</strong>
            <span class="soft-text">@Model.Appointment.PaymentMethod</span>
        </div>
        <div class="detail-card">
            <strong>Total</strong>
            <span class="soft-text">@PortalFormatting.FormatCurrency(Model.Appointment.TotalAmount)</span>
        </div>
    </div>

    <div class="d-flex flex-wrap justify-content-center gap-3 mt-4">
        <a class="btn-brand" asp-action="AppointmentHistory">View history</a>
        <a class="btn-brand-outline" asp-action="Dashboard">Back to dashboard</a>
    </div>
</section>
