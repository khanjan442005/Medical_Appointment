@inject IDemoPortalService PortalService
@{
    var doctor = PortalService.GetCurrentDoctor();
    var today = DateOnly.FromDateTime(DateTime.Today);
    var appointments = PortalService.GetAppointmentsForDoctor(doctor.Id);
    var currentMonthRevenue = appointments
        .Where(appointment => appointment.PaymentCompleted && appointment.AppointmentDate.Year == today.Year && appointment.AppointmentDate.Month == today.Month)
        .Sum(appointment => appointment.TotalAmount);
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    var pageTitle = ViewData["PageTitle"] as string ?? action;
    var pageSubtitle = ViewData["PageSubtitle"] as string ?? "Review appointments, availability, profile, and earnings from one doctor dashboard.";
    var navItems = new[]
    {
        new { Action = "Dashboard", Label = "Overview", Hint = "Clinic snapshot", Index = "01" },
        new { Action = "Appointments", Label = "Appointments", Hint = "Today's patient queue", Index = "02" },
        new { Action = "Profile", Label = "Profile", Hint = "Manage credentials", Index = "03" },
        new { Action = "Availability", Label = "Availability", Hint = "Open and close slots", Index = "04" },
        new { Action = "Earnings", Label = "Earnings", Hint = "Track performance", Index = "05" }
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - MediCore</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="panel-shell panel-doctor">
    <div class="ambient-layer">
        <span class="ambient-orb orb-a" data-orbit></span>
        <span class="ambient-orb orb-b" data-orbit></span>
        <span class="ambient-orb orb-c" data-orbit></span>
    </div>

    <div class="panel-layout">
        <aside class="panel-sidebar glass-surface">
            <div class="panel-sidebar-top">
                <a class="brand-lockup" asp-controller="Doctor" asp-action="Dashboard">
                    <span class="brand-mark">MC</span>
                    <span class="brand-copy">
                        <strong>Doctor Panel</strong>
                        <span>Clinical dashboard</span>
                    </span>
                </a>

                <button class="nav-toggle panel-nav-toggle" type="button" data-nav-toggle data-nav-target="doctor-nav-panel" aria-expanded="false" aria-controls="doctor-nav-panel">
                    <span class="nav-toggle-box" aria-hidden="true">
                        <span></span>
                        <span></span>
                        <span></span>
                    </span>
                    Menu
                </button>
            </div>

            <div class="panel-sidebar-body" id="doctor-nav-panel" data-nav-panel>
                <section class="panel-role-card">
                    <div class="panel-role-copy">
                        <span class="panel-role-badge">Doctor workspace</span>
                        <strong>@doctor.FullName</strong>
                        <p class="soft-text mb-0">Appointments, availability, and earnings now use a tighter clinical navigation flow.</p>
                    </div>
                    <span class="avatar-pill avatar-pill-lg">@doctor.Initials</span>
                </section>

                <div class="panel-nav-head">
                    <span class="soft-text">Navigation grid</span>
                    <strong>Clinical actions</strong>
                </div>

                <nav class="panel-nav" aria-label="Doctor navigation">
                    @foreach (var item in navItems)
                    {
                        <a class="panel-link @(action == item.Action ? "active" : "")" asp-controller="Doctor" asp-action="@item.Action">
                            <span class="panel-link-copy">
                                <strong>@item.Label</strong>
                                <small>@item.Hint</small>
                            </span>
                            <span class="panel-link-index">@item.Index</span>
                        </a>
                    }
                </nav>

                <section class="panel-status glass-surface tilt-card" data-tilt>
                    <span class="soft-text">Clinical lane</span>
                    <strong>@appointments.Count(appointment => appointment.AppointmentDate == today).ToString("D2") appointments scheduled today</strong>
                    <p class="soft-text mb-0">@PortalFormatting.FormatCurrency(currentMonthRevenue) earned this month and @appointments.Count(appointment => appointment.Status == "Payment Pending").ToString("D2") bookings are waiting for payment.</p>
                </section>
            </div>
        </aside>

        <div class="panel-main">
            <header class="panel-topbar glass-surface">
                <div class="panel-heading">
                    <span class="eyebrow">Doctor Panel</span>
                    <h1>@pageTitle</h1>
                    <p class="soft-text mb-0">@pageSubtitle</p>
                </div>

                <div class="panel-topbar-actions">
                    <div class="panel-context-line">
                        <span class="panel-context-pill">@appointments.Count(appointment => appointment.AppointmentDate >= today).ToString("D2") active bookings</span>
                        <span class="panel-context-pill subtle">@PortalFormatting.FormatCurrency(currentMonthRevenue) this month</span>
                    </div>

                    <div class="panel-action-row">
                        <a class="btn-surface" asp-controller="Doctor" asp-action="Appointments">Schedule</a>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn-brand-outline">Log Out</button>
                        </form>
                        <div class="panel-user-chip">
                            <span class="avatar-pill">@doctor.Initials</span>
                            <div class="panel-user-meta">
                                <strong>@doctor.FullName</strong>
                                <span class="panel-user-role">Doctor account</span>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <main class="panel-page">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("PageScripts", required: false)
</body>
</html>
