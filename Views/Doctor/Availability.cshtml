@model DoctorAvailabilityViewModel
@{
    ViewData["Title"] = "Availability";
    ViewData["PageTitle"] = "Availability";
    ViewData["PageSubtitle"] = "Current consultation timings are shared here for the booking flow used by patients.";
    Layout = "~/Views/Doctor/_DoctorLayout.cshtml";
}

<section class="stats-grid">
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Saved blocks</span>
        <strong>@Model.TotalSlotGroupsCount.ToString("D2")</strong>
        <span class="soft-text">Consultation sessions stored for this doctor.</span>
    </article>
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Visible slots</span>
        <strong>@Model.TotalVisibleSlotsCount.ToString("D2")</strong>
        <span class="soft-text">Actual patient-facing time slots in the booking flow.</span>
    </article>
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Active days</span>
        <strong>@Model.ActiveDaysCount.ToString("D2")</strong>
        <span class="soft-text">Distinct days currently visible in the booking flow.</span>
    </article>
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Next availability</span>
        <strong>@Model.NextAvailabilityLabel</strong>
        <span class="soft-text">First saved slot shown from the current doctor schedule.</span>
    </article>
</section>

<section class="dual-grid">
    <article class="section-card glass-surface">
        <div class="section-head">
            <div>
                <span class="eyebrow">Availability</span>
                <h3>Schedule overview</h3>
            </div>
        </div>

        <div class="detail-grid">
            <div class="detail-card">
                <strong>Live booking sync</strong>
                <span class="soft-text">The appointment slots shown to patients are served from this doctor availability setup.</span>
            </div>
            <div class="detail-card">
                <strong>Current mode</strong>
                <span class="soft-text">The schedule remains read-only in demo mode, but it is fully connected to patient bookings.</span>
            </div>
        </div>

        <div class="summary-list mt-4">
            @if (Model.DayBreakdown.Any())
            {
                @foreach (var item in Model.DayBreakdown)
                {
                    <div class="summary-row">
                        <span>
                            <strong>@item.Label</strong>
                            <small class="d-block">@item.Detail</small>
                        </span>
                        <strong>@item.ValueLabel</strong>
                    </div>
                }
            }
            else
            {
                <div class="summary-row">
                    <span>No availability blocks saved.</span>
                    <strong>00</strong>
                </div>
            }
        </div>
    </article>

    <article class="section-card glass-surface">
        <div class="section-head">
            <div>
                <span class="eyebrow">Current schedule</span>
                <h3>Saved timing</h3>
            </div>
        </div>

        <div class="timeline-list">
            @if (Model.Slots.Any())
            {
                @foreach (var slot in Model.Slots)
                {
                    <article class="timeline-item">
                        <div class="timeline-slot">@slot.DayLabel</div>
                        <div class="timeline-copy">
                            <strong>@slot.SessionLabel</strong>
                            <span>@slot.TimeRange</span>
                            <small class="soft-text d-block">Slots: @string.Join(", ", slot.SlotValues)</small>
                        </div>
                        <span class="status-tag">Active</span>
                    </article>
                }
            }
            else
            {
                <article class="timeline-item">
                    <div class="timeline-copy">
                        <strong>No schedule is available yet.</strong>
                        <span>Saved consultation sessions will appear here when availability is configured.</span>
                    </div>
                    <span class="status-tag">Empty</span>
                </article>
            }
        </div>
    </article>
</section>
