@model DoctorDashboardViewModel
@{
    ViewData["Title"] = "Doctor Dashboard";
    ViewData["PageTitle"] = "Doctor Overview";
    ViewData["PageSubtitle"] = "Monitor live bookings, patient volume, pending actions, and earnings from one doctor dashboard.";
    Layout = "~/Views/Doctor/_DoctorLayout.cshtml";
}

<section class="panel-hero glass-surface tilt-card" data-tilt>
    <span class="eyebrow">Doctor summary</span>
    <h2>Welcome back, @Model.Doctor.FullName.</h2>
    <p class="soft-text mb-0">
        Patient bookings, next clinic slots, payment follow-ups, and earnings now sit together inside one sharper doctor workspace.
    </p>
</section>

<section class="stats-grid">
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Today's appointments</span>
        <strong>@Model.TodaysAppointmentsCount.ToString("D2")</strong>
        <span class="soft-text">Schedule count for the current day.</span>
    </article>
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Total patients</span>
        <strong>@Model.TotalPatientsCount.ToString("D2")</strong>
        <span class="soft-text">Distinct patients linked to this doctor.</span>
    </article>
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Pending actions</span>
        <strong>@Model.PendingActionsCount.ToString("D2")</strong>
        <span class="soft-text">@Model.PendingRevenueLabel still depends on payment completion.</span>
    </article>
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Monthly earnings</span>
        <strong>@Model.MonthlyEarningsLabel</strong>
        <span class="soft-text">Paid consultations in the current month.</span>
    </article>
</section>

<section class="dual-grid">
    <article class="section-card glass-surface">
        <div class="section-head">
            <div>
                <span class="eyebrow">Appointment queue</span>
                <h3>Upcoming appointments</h3>
            </div>
            <a class="btn-surface" asp-controller="Doctor" asp-action="Appointments">Full schedule</a>
        </div>

        <div class="summary-list mb-4">
            <div class="summary-row">
                <span>Upcoming bookings</span>
                <strong>@Model.UpcomingAppointmentsCount.ToString("D2")</strong>
            </div>
            <div class="summary-row">
                <span>Completed visits</span>
                <strong>@Model.CompletedAppointmentsCount.ToString("D2")</strong>
            </div>
            <div class="summary-row">
                <span>Pending patient payments</span>
                <strong>@Model.PendingActionsCount.ToString("D2")</strong>
            </div>
            <div class="summary-row">
                <span>Next availability</span>
                <strong>@Model.NextAvailabilityLabel</strong>
            </div>
        </div>

        <div class="timeline-list">
            @if (Model.UpcomingAppointments.Any())
            {
                @foreach (var appointment in Model.UpcomingAppointments)
                {
                    <article class="timeline-item">
                        <div class="timeline-slot">@appointment.TimeSlot</div>
                        <div class="timeline-copy">
                            <strong>@appointment.PatientName</strong>
                            <span>@appointment.DateLabel</span>
                            <small class="soft-text d-block">@appointment.PaymentStatus payment, @appointment.FeeLabel</small>
                        </div>
                        <span class="status-tag">@appointment.Status</span>
                    </article>
                }
            }
            else
            {
                <article class="timeline-item">
                    <div class="timeline-copy">
                        <strong>No upcoming appointments are scheduled right now.</strong>
                        <span>New patient bookings will appear here as soon as they are created.</span>
                    </div>
                    <span class="status-tag">Clear</span>
                </article>
            }
        </div>
    </article>

    <article class="section-card glass-surface">
        <div class="section-head">
            <div>
                <span class="eyebrow">Clinical actions</span>
                <h3>Doctor workspace</h3>
            </div>
        </div>

        <div class="d-grid gap-3 mb-4">
            <a class="btn-brand" asp-controller="Doctor" asp-action="Appointments">Review appointments</a>
            <a class="btn-brand-outline" asp-controller="Doctor" asp-action="Appointments" asp-route-paymentFilter="Pending">Open pending payments</a>
            <a class="btn-brand-outline" asp-controller="Doctor" asp-action="Availability">View availability</a>
            <a class="btn-brand-outline" asp-controller="Doctor" asp-action="Profile">Open profile</a>
        </div>

        <div class="timeline-list mb-4">
            @if (Model.TodayAppointments.Any())
            {
                @foreach (var appointment in Model.TodayAppointments)
                {
                    <article class="timeline-item">
                        <div class="timeline-slot">Today</div>
                        <div class="timeline-copy">
                            <strong>@appointment.PatientName</strong>
                            <span>@appointment.TimeSlot</span>
                            <small class="soft-text d-block">Created @appointment.CreatedAtLabel</small>
                        </div>
                        <span class="status-tag">@appointment.Status</span>
                    </article>
                }
            }
            else
            {
                <article class="timeline-item">
                    <div class="timeline-copy">
                        <strong>No patients in today's queue.</strong>
                        <span>Today's consultation list is currently clear.</span>
                    </div>
                    <span class="status-tag">Open</span>
                </article>
            }
        </div>

        <div class="detail-card">
            <strong>Pending payment follow-up</strong>
            @if (Model.PendingPaymentAppointments.Any())
            {
                <span class="soft-text">These bookings are still waiting for patient payment completion.</span>
                <div class="summary-list mt-3">
                    @foreach (var appointment in Model.PendingPaymentAppointments)
                    {
                        <div class="summary-row">
                            <span>
                                <strong>@appointment.PatientName</strong>
                                <small class="d-block">@appointment.DateLabel, @appointment.TimeSlot</small>
                            </span>
                            <strong>@appointment.FeeLabel</strong>
                        </div>
                    }
                </div>
            }
            else
            {
                <span class="soft-text">No pending patient payments are blocking the doctor queue right now.</span>
            }
        </div>
    </article>
</section>
