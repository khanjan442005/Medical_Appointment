@model DoctorOwnProfileViewModel
@{
    ViewData["Title"] = "Doctor Profile";
    ViewData["PageTitle"] = "Profile";
    ViewData["PageSubtitle"] = "Review doctor information, professional details, and live directory identity.";
    Layout = "~/Views/Doctor/_DoctorLayout.cshtml";
}

<section class="profile-shell glass-surface tilt-card" data-tilt>
    <img src="@Model.Doctor.AvatarPath" alt="@Model.Doctor.FullName" class="avatar-xl" />
    <div>
        <span class="eyebrow">Doctor account</span>
        <h2 class="mt-3 mb-1">@Model.Doctor.FullName</h2>
        <p class="mb-2">@Model.Doctor.Specialization</p>
        <span class="status-tag">Profile active</span>
    </div>
</section>

<section class="stats-grid">
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Appointments</span>
        <strong>@Model.TotalAppointmentsCount.ToString("D2")</strong>
        <span class="soft-text">Total bookings linked to this doctor account.</span>
    </article>
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Upcoming</span>
        <strong>@Model.UpcomingAppointmentsCount.ToString("D2")</strong>
        <span class="soft-text">Future consultations still on the schedule.</span>
    </article>
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Distinct patients</span>
        <strong>@Model.DistinctPatientsCount.ToString("D2")</strong>
        <span class="soft-text">Unique patients already served from this profile.</span>
    </article>
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Lifetime earnings</span>
        <strong>@Model.TotalEarningsLabel</strong>
        <span class="soft-text">Paid consultation total tied to this doctor.</span>
    </article>
</section>

<section class="dual-grid">
    <article class="section-card glass-surface">
        <div class="section-head">
            <div>
                <span class="eyebrow">Professional details</span>
                <h3>Directory information</h3>
            </div>
        </div>

        <div class="detail-grid">
            <article class="detail-card">
                <strong>Email</strong>
                <span class="soft-text">@Model.Doctor.Email</span>
            </article>
            <article class="detail-card">
                <strong>Experience</strong>
                <span class="soft-text">@Model.Doctor.ExperienceYears years</span>
            </article>
            <article class="detail-card">
                <strong>Hospital</strong>
                <span class="soft-text">@Model.Doctor.HospitalName</span>
            </article>
            <article class="detail-card">
                <strong>Specialization</strong>
                <span class="soft-text">@Model.Doctor.Specialization</span>
            </article>
            <article class="detail-card">
                <strong>Location</strong>
                <span class="soft-text">@Model.Doctor.City</span>
            </article>
            <article class="detail-card">
                <strong>Languages</strong>
                <span class="soft-text">@Model.Doctor.Languages</span>
            </article>
            <article class="detail-card">
                <strong>Consultation fee</strong>
                <span class="soft-text">@PortalFormatting.FormatCurrency(Model.Doctor.ConsultationFee)</span>
            </article>
            <article class="detail-card">
                <strong>License number</strong>
                <span class="soft-text">@Model.Doctor.LicenseNumber</span>
            </article>
        </div>
    </article>

    <article class="section-card glass-surface">
        <div class="section-head">
            <div>
                <span class="eyebrow">Profile management</span>
                <h3>Live directory identity</h3>
            </div>
        </div>

        <div class="summary-list">
            <div class="summary-row">
                <span>Directory visibility</span>
                <strong>Visible to patients</strong>
            </div>
            <div class="summary-row">
                <span>Availability blocks</span>
                <strong>@Model.TotalAvailabilityBlocks.ToString("D2") active blocks</strong>
            </div>
            <div class="summary-row">
                <span>Profile rating</span>
                <strong>@Model.Doctor.Rating.ToString("0.0") / 5</strong>
            </div>
            <div class="summary-row">
                <span>Next schedule preview</span>
                <strong>@(Model.AvailabilityPreview.FirstOrDefault()?.DayLabel ?? "Not set")</strong>
            </div>
        </div>

        <div class="detail-card mt-4">
            <strong>Bio</strong>
            <span class="soft-text">@Model.Doctor.Bio</span>
        </div>

        <div class="timeline-list mt-4">
            @if (Model.AvailabilityPreview.Any())
            {
                @foreach (var slot in Model.AvailabilityPreview)
                {
                    <article class="timeline-item">
                        <div class="timeline-slot">@slot.DayLabel</div>
                        <div class="timeline-copy">
                            <strong>@slot.SessionLabel</strong>
                            <span>@slot.TimeRange</span>
                            <small class="soft-text d-block">Slots: @string.Join(", ", slot.SlotValues)</small>
                        </div>
                        <span class="status-tag">Live</span>
                    </article>
                }
            }
            else
            {
                <article class="timeline-item">
                    <div class="timeline-copy">
                        <strong>No schedule preview available.</strong>
                        <span>Availability details will appear here when session data exists.</span>
                    </div>
                    <span class="status-tag">Empty</span>
                </article>
            }
        </div>
    </article>
</section>

<section class="section-card glass-surface">
    <div class="section-head">
        <div>
            <span class="eyebrow">Recent activity</span>
            <h3>Latest patient bookings</h3>
        </div>
        <a class="btn-surface" asp-action="Appointments">Open full schedule</a>
    </div>

    <div class="timeline-list">
        @if (Model.RecentAppointments.Any())
        {
            @foreach (var appointment in Model.RecentAppointments)
            {
                <article class="timeline-item">
                    <div class="timeline-slot">@appointment.TimeSlot</div>
                    <div class="timeline-copy">
                        <strong>@appointment.PatientName</strong>
                        <span>@appointment.DateLabel</span>
                        <small class="soft-text d-block">@appointment.PaymentStatus payment, created @appointment.CreatedAtLabel</small>
                    </div>
                    <span class="status-tag">@appointment.Status</span>
                </article>
            }
        }
        else
        {
            <article class="timeline-item">
                <div class="timeline-copy">
                    <strong>No recent appointments.</strong>
                    <span>New patient bookings will appear here automatically.</span>
                </div>
                <span class="status-tag">Clear</span>
            </article>
        }
    </div>
</section>
