@model ReportsViewModel
@{
    ViewData["Title"] = "Reports";
    ViewData["PageTitle"] = "Reports";
    ViewData["PageSubtitle"] = "Review usage and platform activity derived from the connected patient, doctor, and admin workflows.";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<section class="stats-grid">
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Weekly appointments</span>
        <strong>@Model.Metrics.WeeklyAppointments.ToString("D2")</strong>
        <span class="soft-text">Bookings recorded in the current activity window.</span>
    </article>
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">New registrations</span>
        <strong>@Model.Metrics.NewRegistrations.ToString("D2")</strong>
        <span class="soft-text">Combined patient and doctor signups.</span>
    </article>
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Approval rate</span>
        <strong>@Model.Metrics.ApprovalRateLabel</strong>
        <span class="soft-text">Doctor verification conversion rate.</span>
    </article>
    <article class="stat-card glass-surface tilt-card" data-tilt>
        <span class="soft-text">Revenue trend</span>
        <strong>@Model.Metrics.RevenueTrendLabel</strong>
        <span class="soft-text">Change versus the previous month.</span>
    </article>
</section>

<section class="dual-grid">
    <article class="section-card glass-surface">
        <div class="section-head">
            <div>
                <span class="eyebrow">Appointments</span>
                <h3>Status breakdown</h3>
            </div>
        </div>

        <div class="summary-list">
            @if (Model.AppointmentStatusBreakdown.Any())
            {
                @foreach (var item in Model.AppointmentStatusBreakdown)
                {
                    <div class="summary-row">
                        <span>
                            <strong>@item.Label</strong>
                            <small class="d-block">@item.Detail</small>
                        </span>
                        <strong>@item.ValueLabel</strong>
                    </div>
                }
            }
            else
            {
                <div class="summary-row">
                    <span>No appointment data available.</span>
                    <strong>00</strong>
                </div>
            }
        </div>
    </article>

    <article class="section-card glass-surface">
        <div class="section-head">
            <div>
                <span class="eyebrow">Doctor requests</span>
                <h3>Approval pipeline</h3>
            </div>
        </div>

        <div class="summary-list">
            @if (Model.RequestStatusBreakdown.Any())
            {
                @foreach (var item in Model.RequestStatusBreakdown)
                {
                    <div class="summary-row">
                        <span>
                            <strong>@item.Label</strong>
                            <small class="d-block">@item.Detail</small>
                        </span>
                        <strong>@item.ValueLabel</strong>
                    </div>
                }
            }
            else
            {
                <div class="summary-row">
                    <span>No doctor request data available.</span>
                    <strong>00</strong>
                </div>
            }
        </div>
    </article>
</section>

<section class="dual-grid">
    <article class="section-card glass-surface">
        <div class="section-head">
            <div>
                <span class="eyebrow">Payments</span>
                <h3>Payment method mix</h3>
            </div>
        </div>

        <div class="summary-list">
            @if (Model.PaymentMethodBreakdown.Any())
            {
                @foreach (var item in Model.PaymentMethodBreakdown)
                {
                    <div class="summary-row">
                        <span>
                            <strong>@item.Label</strong>
                            <small class="d-block">@item.Detail</small>
                        </span>
                        <strong>@item.ValueLabel</strong>
                    </div>
                }
            }
            else
            {
                <div class="summary-row">
                    <span>No completed payments found yet.</span>
                    <strong>00</strong>
                </div>
            }
        </div>
    </article>

    <article class="section-card glass-surface">
        <div class="section-head">
            <div>
                <span class="eyebrow">Doctors</span>
                <h3>Top specializations</h3>
            </div>
        </div>

        <div class="summary-list">
            @if (Model.SpecializationBreakdown.Any())
            {
                @foreach (var item in Model.SpecializationBreakdown)
                {
                    <div class="summary-row">
                        <span>
                            <strong>@item.Label</strong>
                            <small class="d-block">@item.Detail</small>
                        </span>
                        <strong>@item.ValueLabel</strong>
                    </div>
                }
            }
            else
            {
                <div class="summary-row">
                    <span>No specialization data available.</span>
                    <strong>00</strong>
                </div>
            }
        </div>
    </article>
</section>
